# Downloads / modlist state the user runs with
modlist_*.txt
loadorder_*.txt
nerevarine_prefs.ini

# Auto-rotated modlist snapshots (the app keeps the last 5 on disk itself):
#   *.bak.<YYYYMMDD-HHMMSS>  - every save rotates one of these
#   *.good.<YYYYMMDD-HHMMSS> - known-good marker taken on clean exit
#   *.premanualedit          - written before the user hand-edits the file
# None of them belong in version control - they churn on every launch.
modlist_*.txt.bak.*
modlist_*.txt.good.*
modlist_*.txt.premanualedit

# Translation coverage stubs (regenerate with scripts/translation_coverage.sh)
translations/_missing/

# OS cruft
.DS_Store
Thumbs.db
